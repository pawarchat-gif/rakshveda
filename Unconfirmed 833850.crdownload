    def extract_dna(self, filepath):
        """PERFECT DNA extraction - accurate for ALL file types"""
        try:
            # STEP 1: Get real file type
            file_type, category = self.file_validator.identify_file_type(filepath)
            
            # Read file content
            with open(filepath, 'rb') as f:
                content = f.read()
            
            file_size = len(content)
            
            # STEP 2: Calculate entropy
            entropy = self._calculate_entropy(content)
            
            # STEP 3: Extract behaviors and API patterns
            behaviors = self._extract_behaviors(content)
            api_patterns = self._extract_api_patterns(content)
            
            # STEP 4: SCAN FOR MALWARE SIGNATURES (works for ALL file types)
            malware_scan = self._scan_malware_signatures(content, api_patterns, entropy, file_type, category)
            
            # STEP 5: Determine if file is actually malicious
            is_malicious = malware_scan['is_malicious']
            
            # STEP 6: Calculate mutation score
            if is_malicious:
                mutation_score = self._calculate_mutation_score(
                    content, entropy, behaviors, api_patterns, malware_scan
                )
            else:
                # Clean files get ZERO or very low mutation score
                mutation_score = self._calculate_clean_file_score(entropy, file_type, category)
            
            # STEP 7: Determine threat family
            if is_malicious:
                threat_family = malware_scan['primary_threat']
            else:
                threat_family = self._determine_clean_label(file_type, category, entropy, behaviors)
            
            dna_hash = hashlib.sha256(content[:20480]).hexdigest()
            
            dna_profile = {
                'file_hash': dna_hash,
                'entropy': entropy,
                'behaviors': behaviors,
                'api_patterns': api_patterns,
                'mutation_score': mutation_score,
                'threat_family': threat_family,
                'file_type': file_type,
                'category': category,
                'is_malicious': is_malicious,
                'malware_scan': {
                    'detected_threats': malware_scan['detected_threats'],
                    'primary_threat': malware_scan['primary_threat'],
                    'confidence': malware_scan['confidence'],
                    'threat_level': malware_scan['threat_level']
                },
                'timestamp': datetime.now().isoformat(),
                'size': file_size,
                'sha256': hashlib.sha256(content).hexdigest(),
                'md5': hashlib.md5(content).hexdigest()
            }
            
            # Save profile
            os.makedirs('dna_profiles', exist_ok=True)
            profile_path = os.path.join('dna_profiles', f"{dna_hash[:16]}.json")
            with open(profile_path, 'w') as f:
                json.dump(dna_profile, f, indent=2, default=str)
            
            return dna_profile
            
        except Exception as e:
            return {
                'error': str(e),
                'threat_family': 'Analysis Error',
                'mutation_score': 0,
                'is_malicious': False,
                'malware_scan': {'detected_threats': [], 'primary_threat': 'None', 'confidence': 0, 'threat_level': 'CLEAN'}
            }
    
    def _scan_malware_signatures(self, content, api_patterns, entropy, file_type, category):
        """Scan content against ALL malware signatures"""
        detected_threats = []
        api_names = [api['api'] for api in api_patterns]
        
        # Only do deep scan if file could potentially contain malware
        # Skip pure media files unless they have very high entropy (steganography)
        if category == 'MEDIA' and entropy < 7.0 and file_type not in ['ZIP', 'RAR']:
            # Quick check for steganography (hidden payload in media)
            if entropy > 6.5:
                # Check for embedded executables
                if b'MZ' in content or b'\x7fELF' in content:
                    detected_threats.append({
                        'family': 'embedded_payload',
                        'name': 'Hidden Executable in Media File',
                        'confidence': 0.85,
                        'threat_level': 'CRITICAL'
                    })
            return {
                'is_malicious': len(detected_threats) > 0,
                'detected_threats': detected_threats,
                'primary_threat': 'Clean Media File' if not detected_threats else 'Embedded Threat in Media',
                'confidence': max([t['confidence'] for t in detected_threats]) if detected_threats else 0,
                'threat_level': 'CLEAN' if not detected_threats else 'CRITICAL'
            }
        
        # Deep scan for all file types
        for family, sig_data in self.malware_signatures.items():
            match_result = self._match_family(content, api_names, entropy, family, sig_data)
            if match_result['matched']:
                detected_threats.append(match_result)
        
        # Also check for generic malicious indicators
        generic_threats = self._check_generic_threats(content, api_names, entropy, file_type, category)
        detected_threats.extend(generic_threats)
        
        # Determine overall result
        if detected_threats:
            # Sort by confidence
            detected_threats.sort(key=lambda x: x['confidence'], reverse=True)
            primary = detected_threats[0]
            
            return {
                'is_malicious': True,
                'detected_threats': detected_threats[:5],
                'primary_threat': primary['name'],
                'confidence': primary['confidence'],
                'threat_level': primary['threat_level']
            }
        else:
            return {
                'is_malicious': False,
                'detected_threats': [],
                'primary_threat': self._determine_clean_label(file_type, category, entropy, {}),
                'confidence': 0,
                'threat_level': 'CLEAN'
            }
    
    def _match_family(self, content, api_names, entropy, family, sig_data):
        """Match file against a specific malware family signature"""
        # Count binary pattern matches
        pattern_matches = []
        for pattern in sig_data['binary_patterns']:
            if pattern in content:
                pattern_matches.append(pattern)
        
        # Count API matches
        api_matches = [api for api in sig_data['api_patterns'] if api in api_names]
        
        # Check entropy range
        ent_min, ent_max = sig_data['entropy_range']
        entropy_match = ent_min <= entropy <= ent_max
        
        # Calculate match scores
        pattern_score = len(pattern_matches) / max(sig_data['min_pattern_matches'], 1)
        api_score = len(api_matches) / max(sig_data['min_api_matches'], 1)
        
        # Calculate confidence
        confidence = (pattern_score * 0.5) + (api_score * 0.35) + (0.15 if entropy_match else 0)
        confidence = min(confidence, 1.0)
        
        # Match if meets minimum requirements
        min_patterns_met = len(pattern_matches) >= sig_data['min_pattern_matches']
        min_apis_met = len(api_matches) >= sig_data['min_api_matches']
        
        # Lower thresholds for certain families
        if family in ['shellcode', 'meterpreter']:
            min_patterns_met = len(pattern_matches) >= 1 or entropy > 7.5
            min_apis_met = len(api_matches) >= 2
        
        matched = (min_patterns_met or min_apis_met) and confidence > 0.3
        
        if matched:
            confidence = max(confidence, 0.4)  # Minimum confidence for matches
        
        return {
            'matched': matched,
            'family': family,
            'name': self._get_family_display_name(family),
            'confidence': round(confidence, 3),
            'threat_level': sig_data['threat_level'],
            'pattern_matches': [p.decode('ascii', errors='ignore')[:50] for p in pattern_matches[:5]],
            'api_matches': api_matches[:5],
            'pattern_count': len(pattern_matches),
            'api_count': len(api_matches)
        }
    
    def _check_generic_threats(self, content, api_names, entropy, file_type, category):
        """Check for generic threat indicators not tied to specific families"""
        threats = []
        
        # Check for obfuscated/packed content
        if entropy > 7.5 and len(content) > 1024:
            if b'MZ' in content or b'\x7fELF' in content:
                threats.append({
                    'matched': True,
                    'family': 'packed_executable',
                    'name': 'Packed/Obfuscated Executable',
                    'confidence': 0.75,
                    'threat_level': 'HIGH',
                    'pattern_matches': ['High entropy packed content'],
                    'api_matches': [],
                    'pattern_count': 1,
                    'api_count': 0
                })
        
        # Check for suspicious API combinations
        injection_apis = ['VirtualAlloc', 'WriteProcessMemory', 'CreateRemoteThread']
        network_apis = ['socket', 'connect', 'InternetConnect', 'HttpOpenRequest']
        evasion_apis = ['IsDebuggerPresent', 'CheckRemoteDebuggerPresent', 'GetTickCount']
        
        injection_count = sum(1 for api in injection_apis if api in api_names)
        network_count = sum(1 for api in network_apis if api in api_names)
        evasion_count = sum(1 for api in evasion_apis if api in api_names)
        
        if injection_count >= 2 and network_count >= 2:
            threats.append({
                'matched': True,
                'family': 'suspicious_combination',
                'name': 'Suspicious API Combination (Injection + Network)',
                'confidence': 0.7,
                'threat_level': 'HIGH',
                'pattern_matches': [],
                'api_matches': [a for a in injection_apis + network_apis if a in api_names],
                'pattern_count': 0,
                'api_count': injection_count + network_count
            })
        
        if injection_count >= 2 and evasion_count >= 1:
            threats.append({
                'matched': True,
                'family': 'suspicious_evasion',
                'name': 'Potential Malware with Evasion Techniques',
                'confidence': 0.65,
                'threat_level': 'HIGH',
                'pattern_matches': [],
                'api_matches': [a for a in injection_apis + evasion_apis if a in api_names],
                'pattern_count': 0,
                'api_count': injection_count + evasion_count
            })
        
        return threats
    
    def _get_family_display_name(self, family):
        """Get readable display name for malware family"""
        names = {
            'meterpreter': 'Metasploit/Meterpreter Payload',
            'cobalt_strike': 'Cobalt Strike Beacon',
            'ransomware': 'Ransomware',
            'rat_trojan': 'Remote Access Trojan (RAT)',
            'spyware': 'Keylogger/Spyware',
            'rootkit': 'Rootkit/Bootkit',
            'infostealer': 'Information Stealer',
            'botnet': 'Botnet/DDoS Agent',
            'shellcode': 'Shellcode/Exploit Payload'
        }
        return names.get(family, family.replace('_', ' ').title())
    
    def _determine_clean_label(self, file_type, category, entropy, behaviors):
        """Determine label for clean files"""
        if category == 'MEDIA':
            return f'Clean {file_type} Image/Media File'
        elif category == 'TEXT':
            return f'Clean Text/Document File'
        elif file_type in ['PDF', 'HTML', 'XML', 'JSON']:
            return f'Clean {file_type} Document'
        elif file_type in ['ZIP', 'RAR', 'GZIP']:
            if len(behaviors) > 0 or entropy > 6.0:
                return f'{file_type} Archive (Suspicious - Contains Executable Code)'
            return f'Clean {file_type} Archive'
        else:
            if entropy > 7.0:
                return 'Unknown File (High Entropy - Encrypted/Compressed)'
            return 'Clean Unknown File'
    
    def _calculate_entropy(self, data):
        """Calculate Shannon entropy"""
        if not data or len(data) == 0:
            return 0
        try:
            sample = data[:100000]
            byte_counts = np.bincount(np.frombuffer(sample, dtype=np.uint8), minlength=256)
            byte_probs = byte_counts / len(sample)
            byte_probs = byte_probs[byte_probs > 0]
            entropy = -np.sum(byte_probs * np.log2(byte_probs))
            return round(float(entropy), 4)
        except:
            return 0
    
    def _extract_behaviors(self, content):
        """Extract behavioral patterns"""
        detected = {}
        for category, patterns in self.behavioral_categories.items():
            matches = []
            for pattern in patterns:
                if pattern in content:
                    matches.append(pattern.decode('ascii', errors='ignore'))
            if matches:
                detected[category] = matches
        return detected
    
    def _extract_api_patterns(self, content):
        """Extract Windows API patterns"""
        api_patterns = []
        apis = [
            b'VirtualAlloc', b'VirtualAllocEx', b'VirtualProtect', b'VirtualFree',
            b'CreateThread', b'CreateRemoteThread', b'OpenProcess', b'OpenThread',
            b'WriteProcessMemory', b'ReadProcessMemory', b'GetProcAddress',
            b'LoadLibrary', b'LoadLibraryEx', b'FreeLibrary',
            b'CreateProcess', b'CreateProcessAsUser', b'TerminateProcess',
            b'CreateFile', b'ReadFile', b'WriteFile', b'DeleteFile',
            b'FindFirstFile', b'FindNextFile', b'CopyFile', b'MoveFile',
            b'socket', b'connect', b'bind', b'listen', b'send', b'recv',
            b'WSAStartup', b'WSASocket', b'gethostbyname',
            b'InternetOpen', b'InternetConnect', b'HttpOpenRequest',
            b'HttpSendRequest', b'InternetReadFile', b'URLDownloadToFile',
            b'WinHttpOpen', b'WinHttpConnect', b'WinHttpSendRequest',
            b'CryptEncrypt', b'CryptDecrypt', b'CryptGenKey', b'CryptAcquireContext',
            b'RegOpenKey', b'RegSetValue', b'RegCreateKey', b'RegCloseKey',
            b'CreateService', b'OpenSCManager', b'StartService',
            b'SetWindowsHookEx', b'GetAsyncKeyState', b'GetClipboardData',
            b'GetForegroundWindow', b'GetWindowText',
            b'IsDebuggerPresent', b'CheckRemoteDebuggerPresent',
            b'OpenProcessToken', b'AdjustTokenPrivileges', b'LookupPrivilegeValue',
            b'NtCreateThreadEx', b'QueueUserAPC', b'RtlCreateUserThread',
            b'ShellExecute', b'WinExec', b'system'
        ]
        
        search_range = content[:200000]
        for api in apis:
            count = search_range.count(api)
            if count > 0:
                api_patterns.append({
                    'api': api.decode('ascii'),
                    'occurrences': count,
                    'positions': []
                })
        
        api_patterns.sort(key=lambda x: x['occurrences'], reverse=True)
        return api_patterns
    
    def _calculate_mutation_score(self, content, entropy, behaviors, api_patterns, malware_scan):
        """Calculate mutation score for MALICIOUS files"""
        score = 0.0
        
        # Base score from threat detection
        if malware_scan['confidence'] > 0.8:
            score += 35
        elif malware_scan['confidence'] > 0.6:
            score += 25
        elif malware_scan['confidence'] > 0.4:
            score += 15
        
        # Entropy contribution
        if entropy > 7.5:
            score += 25
        elif entropy > 7.0:
            score += 18
        elif entropy > 6.5:
            score += 12
        
        # Behavior diversity
        behavior_count = len(behaviors)
        score += behavior_count * 6
        
        # API complexity
        unique_apis = len(set(api['api'] for api in api_patterns))
        if unique_apis > 20:
            score += 15
        elif unique_apis > 10:
            score += 8
        
        # Multiple threat families detected
        threat_count = len(malware_scan['detected_threats'])
        if threat_count > 2:
            score += 12
        elif threat_count > 1:
            score += 6
        
        return min(round(score, 2), 100)
    
    def _calculate_clean_file_score(self, entropy, file_type, category):
        """Calculate score for CLEAN files (always very low)"""
        # Media files
        if category == 'MEDIA':
            if entropy > 7.5:
                return 8.0  # Suspiciously high entropy for media
            elif entropy > 6.5:
                return 4.0
            else:
                return 0.0
        
        # Archives
        if file_type in ['ZIP', 'RAR', 'GZIP']:
            if entropy > 7.0:
                return 10.0  # Could contain encrypted payload
            return 2.0
        
        # Unknown files with high entropy
        if entropy > 7.5:
            return 12.0
        elif entropy > 7.0:
            return 6.0
        
        return 0.0
    
    def predict_mutations(self, dna_profile):
        """Predict mutations ONLY for actual malware"""
        
        # NO predictions for clean files
        if not dna_profile.get('is_malicious', False):
            return []
        
        malware_scan = dna_profile.get('malware_scan', {})
        if malware_scan.get('threat_level') == 'CLEAN':
            return []
        
        predictions = []
        entropy = dna_profile.get('entropy', 0)
        behaviors = dna_profile.get('behaviors', {})
        mutation_score = dna_profile.get('mutation_score', 0)
        primary_threat = malware_scan.get('primary_threat', '')
        confidence = malware_scan.get('confidence', 0)
        
        # Prediction 1: Encryption/Obfuscation Evolution
        if entropy > 6.5 or 'evasion' in behaviors:
            prob = min(0.88, 0.55 + (entropy - 6.5) * 0.15 + confidence * 0.2)
            predictions.append({
                'probability': round(prob, 3),
                'mutation_type': 'Encryption & Obfuscation Enhancement',
                'description': f'Next variant will implement stronger encryption and code obfuscation to evade detection. Expected entropy increase in next iteration.',
                'risk_level': 'CRITICAL' if prob > 0.8 else 'HIGH',
                'mutation_timeline': '1-3 days' if prob > 0.75 else '3-7 days',
                'indicators': ['Entropy increase', 'New encryption layer', 'Code obfuscation']
            })
        
        # Prediction 2: Anti-Analysis Evolution
        if 'evasion' in behaviors or 'injection' in behaviors:
            prob = min(0.85, 0.50 + confidence * 0.3)
            predictions.append({
                'probability': round(prob, 3),
                'mutation_type': 'Anti-Analysis & Evasion Upgrade',
                'description': 'Will implement advanced VM detection, sandbox evasion, and debugger anti-attach techniques.',
                'risk_level': 'CRITICAL' if prob > 0.75 else 'HIGH',
                'mutation_timeline': '2-5 days',
                'indicators': ['VM detection', 'Sandbox evasion', 'Debugger detection', 'Timing checks']
            })
        
        # Prediction 3: C2 Communication Evolution
        if 'network_ops' in behaviors:
            prob = min(0.82, 0.50 + confidence * 0.25)
            predictions.append({
                'probability': round(prob, 3),
                'mutation_type': 'C2 Protocol Diversification',
                'description': 'Command & Control will evolve to use multiple protocols (HTTPS, DNS, WebSocket) with domain generation algorithms for resilience.',
                'risk_level': 'HIGH',
                'mutation_timeline': '3-7 days',
                'indicators': ['Multi-protocol C2', 'Domain generation', 'Fallback channels']
            })
        
        # Prediction 4: Persistence Multiplication
        if 'persistence' in behaviors:
            prob = min(0.80, 0.50 + confidence * 0.2)
            predictions.append({
                'probability': round(prob, 3),
                'mutation_type': 'Multi-Vector Persistence',
                'description': 'Will deploy multiple persistence mechanisms (Registry, Scheduled Tasks, WMI, Services) for redundancy.',
                'risk_level': 'HIGH',
                'mutation_timeline': '2-4 days',
                'indicators': ['Registry persistence', 'Scheduled tasks', 'WMI subscriptions', 'Service installation']
            })
        
        # Prediction 5: Complete Metamorphic Transformation
        if mutation_score > 60:
            prob = min(0.90, 0.65 + (mutation_score - 60) * 0.008)
            predictions.append({
                'probability': round(prob, 3),
                'mutation_type': 'Polymorphic Code Transformation',
                'description': 'High probability of complete code restructuring with polymorphic engine. Each instance will have unique signature.',
                'risk_level': 'CRITICAL',
                'mutation_timeline': '24-48 hours',
                'indicators': ['Code restructuring', 'Polymorphic engine', 'Unique signatures', 'Junk code insertion']
            })
        
        # Prediction 6: Privilege Escalation Enhancement
        if 'privilege_escalation' in behaviors:
            prob = min(0.78, 0.50 + confidence * 0.2)
            predictions.append({
                'probability': round(prob, 3),
                'mutation_type': 'Zero-Day Privilege Escalation',
                'description': 'Will incorporate latest privilege escalation exploits targeting unpatched vulnerabilities.',
                'risk_level': 'CRITICAL' if prob > 0.7 else 'HIGH',
                'mutation_timeline': '5-14 days',
                'indicators': ['Zero-day research', 'Kernel exploitation', 'Token manipulation']
            })
        
        predictions.sort(key=lambda x: x['probability'], reverse=True)
        return predictions


class VulnerabilityIntelligence:
    """Accurate vulnerability correlation"""
    
    def __init__(self):
        self.cve_database = {
            'code_injection': {
                'cves': ['CVE-2023-23397', 'CVE-2022-41082', 'CVE-2021-34527', 
                        'CVE-2023-36884', 'CVE-2022-41128'],
