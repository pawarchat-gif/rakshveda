                        'CVE-2023-36874', 'CVE-2022-24521'],
                'severity': 'HIGH',
                'exploit_maturity': 'PROOF_OF_CONCEPT',
                'affected_systems': ['Windows Kernel', 'Win32k', 'NTFS Driver']
            },
            'remote_execution': {
